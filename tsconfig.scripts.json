{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": [
    "scripts/**/*",
    "src/lib/types.ts",
    "src/matching/**/*",
    "src/parsers/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
